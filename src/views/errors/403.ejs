<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>403 - Akses Ditolak | Sistem Logistik</title>

    <!-- Tailwind CDN -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Basecoat UI -->
    <link href="https://cdn.jsdelivr.net/npm/basecoat-css@0.3.2/dist/basecoat.min.css" rel="stylesheet">

    <!-- CSS Pegawai (shared styles) -->
    <link rel="stylesheet" href="/css/pegawai.css">
</head>
<body class="app-body error-page-body">

    <!-- Navbar (jika user sudah login) -->
    <% if (locals.user) { %>
        <%- include('../partials/navbar', { user: user, activePage: '' }) %>
    <% } %>

    <main class="error-page">
        <div class="error-container">

            <!-- Ilustrasi angka error -->
            <div class="error-code error-code-403">403</div>

            <div class="error-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
            </div>

            <h1 class="error-title">Akses Ditolak</h1>

            <p class="error-message">
                Maaf, Anda tidak memiliki izin untuk mengakses halaman ini.
                Halaman ini hanya dapat diakses oleh pengguna dengan hak akses yang sesuai.
            </p>

            <div class="error-actions">
                <% if (locals.user && user.role === 'admin') { %>
                    <a href="/admin" class="btn btn-primary">Kembali ke Dashboard Admin</a>
                <% } else if (locals.user && user.role === 'pegawai') { %>
                    <a href="/pegawai" class="btn btn-primary">Kembali ke Dashboard Pegawai</a>
                <% } else { %>
                    <a href="/login" class="btn btn-primary">Login</a>
                <% } %>
                <a href="javascript:history.back()" class="btn btn-outline">Kembali</a>
            </div>

        </div>
    </main>

</body>
</html>
