<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Pegawai | Sistem Logistik</title>

    <!-- Tailwind CDN -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Basecoat UI -->
    <link href="https://cdn.jsdelivr.net/npm/basecoat-css@0.3.2/dist/basecoat.min.css" rel="stylesheet">

    <!-- CSS Pegawai -->
    <link rel="stylesheet" href="/css/pegawai.css">
</head>
<body class="app-body">

    <!-- Navbar -->
    <%- include('../partials/navbar', { user: user, activePage: activePage }) %>

    <!-- Main Content -->
    <main class="app-main">

        <!-- Flash Message -->
        <%- include('../partials/flash') %>

        <!-- Header Halaman -->
        <div class="page-header">
            <div>
                <h1 class="page-title">Selamat Datang, <%= user.nama %> 👋</h1>
                <p class="page-subtitle">Dashboard Pegawai — Sistem Logistik FTI</p>
            </div>
            <div class="badge badge-pegawai"><%= user.role %></div>
        </div>

        <!-- Stats Cards -->
        <div class="stats-grid">

            <div class="stat-card stat-card-blue">
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2"/>
                    </svg>
                </div>
                <div class="stat-info">
                    <p class="stat-label">Total Permintaan</p>
                    <p class="stat-value">—</p>
                </div>
            </div>

            <div class="stat-card stat-card-yellow">
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                    </svg>
                </div>
                <div class="stat-info">
                    <p class="stat-label">Menunggu Persetujuan</p>
                    <p class="stat-value">—</p>
                </div>
            </div>

            <div class="stat-card stat-card-green">
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                </div>
                <div class="stat-info">
                    <p class="stat-label">Disetujui</p>
                    <p class="stat-value">—</p>
                </div>
            </div>

            <div class="stat-card stat-card-red">
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </div>
                <div class="stat-info">
                    <p class="stat-label">Ditolak</p>
                    <p class="stat-value">—</p>
                </div>
            </div>

        </div>

        <!-- Info Card -->
        <div class="info-card">
            <div class="info-card-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 8h14M5 8a2 2 0 1 0 0-4h14a2 2 0 1 0 0 4M5 8v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8m-9 4h4"/>
                </svg>
            </div>
            <div class="info-card-content">
                <h2 class="info-card-title">Modul Transaksi Checkout</h2>
                <p class="info-card-desc">
                    Fitur pengelolaan permintaan barang logistik akan segera tersedia.
                    Melalui modul ini, Anda dapat mengajukan, melacak, dan mengelola
                    seluruh permintaan logistik Anda secara real-time.
                </p>
                <div class="info-card-badges">
                    <span class="badge badge-outline">Buat Permintaan</span>
                    <span class="badge badge-outline">Lacak Status</span>
                    <span class="badge badge-outline">Riwayat Transaksi</span>
                </div>
            </div>
        </div>

        <!-- Info Akun -->
        <div class="account-card">
            <h3 class="account-card-title">Informasi Akun</h3>
            <div class="account-grid">
                <div class="account-item">
                    <span class="account-label">Nama</span>
                    <span class="account-value"><%= user.nama %></span>
                </div>
                <div class="account-item">
                    <span class="account-label">Role</span>
                    <span class="account-value">
                        <span class="badge badge-pegawai"><%= user.role %></span>
                    </span>
                </div>
            </div>
        </div>

    </main>

    <!-- Footer -->
    <footer class="app-footer">
        <p>&copy; 2025 FTI Logistik &mdash; Sistem Manajemen Transaksi Checkout</p>
    </footer>

</body>
</html>
