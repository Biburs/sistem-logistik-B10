<%# partials/flash.ejs — Pesan flash notifikasi (sukses / error / warning) %>
<%# Author: Mahasiswa 3 - Taris Rafivdean %>

<% if (locals.flash) { %>
    <% if (flash.success) { %>
        <div class="flash flash-success" id="flash-message">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <span><%= flash.success %></span>
            <button class="flash-close" onclick="this.parentElement.remove()">&times;</button>
        </div>
    <% } %>

    <% if (flash.error) { %>
        <div class="flash flash-error" id="flash-message">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <span><%= flash.error %></span>
            <button class="flash-close" onclick="this.parentElement.remove()">&times;</button>
        </div>
    <% } %>

    <% if (flash.warning) { %>
        <div class="flash flash-warning" id="flash-message">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            <span><%= flash.warning %></span>
            <button class="flash-close" onclick="this.parentElement.remove()">&times;</button>
        </div>
    <% } %>
<% } %>

<% if (locals.error) { %>
    <div class="flash flash-error" id="flash-message">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <span><%= error %></span>
        <button class="flash-close" onclick="this.parentElement.remove()">&times;</button>
    </div>
<% } %>

<script>
    // Auto-dismiss flash message setelah 4 detik
    setTimeout(() => {
        const flash = document.getElementById('flash-message');
        if (flash) {
            flash.style.opacity = '0';
            flash.style.transform = 'translateY(-10px)';
            flash.style.transition = 'all 0.4s ease';
            setTimeout(() => flash.remove(), 400);
        }
    }, 4000);
</script>
